{
  "manifest_version": 3,
  "name": "D365 Service Atlas",
  "version": "1.0.0.0",
  "description": "Browse and inspect Dynamics 365 Finance & Operations service groups, operations, and types.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "D365 Service Atlas",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "sidePanel"],
  "host_permissions": [
    "https://*.operations.dynamics.com/*",
    "https://*.axcloud.dynamics.com/*"
  ]
}
